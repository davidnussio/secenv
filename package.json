{
  "name": "@oggi.ch/secenv",
  "version": "0.1.0",
  "description": "Secure environment secrets management using macOS Keychain",
  "type": "module",
  "bin": {
    "secenv": "./bin/secenv"
  },
  "files": [
    "bin/secenv",
    "src/**/*.ts"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "os": [
    "darwin"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck"
  },
  "keywords": [
    "secrets",
    "environment-variables",
    "keychain",
    "macos",
    "bun",
    "effect",
    "cli"
  ],
  "author": "David Nussio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidnussio/secenv.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "bun": ">=1.0.0",
    "@effect/cli": "^0.73.2",
    "@effect/platform": "^0.94.5",
    "@effect/platform-bun": "^0.87.1",
    "effect": "^3.19.19"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
