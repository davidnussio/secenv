{
  "name": "envsec",
  "version": "0.1.5",
  "description": "Secure environment secrets management using native OS credential stores",
  "type": "module",
  "bin": {
    "secenv": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "secrets",
    "environment-variables",
    "keychain",
